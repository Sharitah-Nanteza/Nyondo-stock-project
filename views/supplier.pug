extends layout

block content 
  .dashboard
    h1 Supplier Management
    
    //- Action Controls Section (Aligns the toggle button cleanly to the right side at the top)
    .d-flex.justify-content-end.mb-3
      if dbStock.length > 5
        button#toggleRowsBtn.btn.btn-outline-primary(type="button" onclick="toggleExtraRows()") View All Suppliers
    
    table
      thead
        tr
          th Factory Name
          th Supplier Name
          th Factory Contact
          th Product Name
          th Total
          th Quantity
          th Date
          th Payment Status
          if user.userrole === "stockmanager" || user.userrole === "admin"
            th Action
      tbody
        each product, index in dbStock
          //- If the index is 5 or greater, add 'extra-row d-none' to hide it by default
          tr(class=index >= 5 ? 'extra-row d-none' : '')
            td #{product.factoryname}
            td #{product.suppliername}
            td #{product.suppliercontact}
            td #{product.productname}
            td #{product.total}
            td #{product.originalQuantity}
            td #{new Date(product.date).toLocaleString()}
            td #{product.paymentstatus}
            if user.userrole === "stockmanager" || user.userrole === "admin"
              td 
                .d-flex.gap-2 
                  a.btn.btn-sm.btn-outline-warning(href=`/supplier/edit/${product._id}`)
                    i.fas.fa-edit
                  form(action=`/delete/${product._id}` method="post" onsubmit='return confirm("Are you sure you want to delete this item?");')
                    button.btn.btn-sm.btn-outline-danger(type='submit')
                      i.fas.fa-trash-alt 
        if dbStock.length === 0
          tr 
            td.text-center(colspan='9') No supplier records have been found.

  //- Reusable script tailored for the supplier page
  script.
    function toggleExtraRows() {
      const extraRows = document.querySelectorAll('.extra-row');
      const btn = document.getElementById('toggleRowsBtn');
      
      const isHidden = extraRows[0].classList.contains('d-none');
      
      extraRows.forEach(row => {
        if (isHidden) {
          row.classList.remove('d-none');
          btn.innerText = 'Show Less';
        } else {
          row.classList.add('d-none');
          btn.innerText = 'View All Suppliers';
        }
      });
    }