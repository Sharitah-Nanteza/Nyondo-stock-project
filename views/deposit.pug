extends layout

block content 
  .container
    .header
      div
        h1 Customer Deposit Scheme
        p #{(customers || []).length} Customers 
      .text-center
        a.btn-credit(href='/deposited') + Register Customer
    
    .stats-grid
      .stat-card
        h3 Active Customers
        p #{(customers || []).filter(c => c.outstandingBalance > 0).length}
      .stat-card
        h3 Total Deposited
        p #{ (customers || []).reduce((sum, c) => sum + (c.amountDeposited || 0), 0).toLocaleString() } UGX
      .stat-card
        h3 Completed
        p #{(customers || []).filter(c => c.outstandingBalance <= 0).length}
      .stat-card
        h3 Total Outstanding Balance
        p(style="color: #d9534f; font-weight: bold;") #{ (customers || []).reduce((sum, c) => sum + (c.outstandingBalance || 0), 0).toLocaleString() } UGX

    //- 1. Main block: Check if customers exist first
    if customers && customers.length
      
      //- 2. Your View All Button placed beautifully at the top of the list area
      if customers.length > 1
        .text-center.mt-4(style="margin-bottom: 20px;")
          button#toggleRowsBtn.btn.btn-outline-primary(type="button" onclick="toggleExtraRows()") View All Deposits

      //- Loop through all customers using the index tracking
      each customer, index in customers
        //- If it's the first card (index 0), it renders normally. 
        //- If it's index 1 or greater, we slap the 'extra-row d-none' class on it to hide it.
        div(class=index >= 1 ? 'extra-row d-none' : '')
          if index === 0
            h3#activityHeading(style="margin-top: 25px; color: #2c3e50; font-size: 1.1rem; margin-bottom: 15px;") 🕒 Latest Activity
          
          .customer-card
            .customer-header
              div
                strong(style='font-size: 1.2rem')= customer.fullName
                div(style='font-size: 0.85rem; color: #7f8c8d')
                  | NIN: #{customer.nin || 'N/A'} &bull; #{customer.phonenumber} &bull;  #{customer.customeraddress}  (#{customer.customerdistance}km)
              if customer.outstandingBalance <= 0
                span.badge(style="background-color: #28a745; color: white; padding: 5px 12px; border-radius: 4px; font-weight: bold; font-size: 13px;") Paid
              else
                span.badge(style="background-color: #f0ad4e; color: white; padding: 5px 12px; border-radius: 4px; font-weight: bold; font-size: 13px;") Pending
            
            //- Scheme Items Layout
            div(style="background: #fdfdfd; border: 1px solid #f0f4f8; border-radius: 6px; padding: 12px; margin-bottom: 15px;")
              strong(style="font-size: 0.85rem; color: #2563eb; text-transform: uppercase; display: block; margin-bottom: 8px;") Product
              if customer.depositedItems && customer.depositedItems.length > 0
                each item in customer.depositedItems
                  div(style="display: flex; justify-content: space-between; font-size: 0.95rem; padding: 6px 0; border-bottom: 1px dashed #f0f4f8;")
                    span(style="font-weight: 500;") #{item.productname ? item.productname.productname : 'General Hardware'}
                    span(style="color: #555;") x#{item.quantity} (UGX #{item.priceAtDeposit.toLocaleString()})
              else
                div(style="font-size: 0.95rem; color: #7f8c8d; font-style: italic;") General Hardware Order (Legacy Record)

            .info-grid
              .info-item
                label Total Amount
                span #{customer.total ? customer.total.toLocaleString() : '0'} UGX
              .info-item
                label Amount deposited
                span #{customer.amountDeposited ? customer.amountDeposited.toLocaleString() : '0'} UGX
              .info-item
                label Balance Remaining
                span(style=customer.outstandingBalance > 0 ? "color: #d9534f; font-weight: bold;" : "color: #28a745; font-weight: bold;") #{customer.outstandingBalance ? customer.outstandingBalance.toLocaleString() : '0'} UGX
            
            .text-center(style="margin-top: 15px;")
              a.btn-login(href=`/record/${customer._id}`) Record Deposit
    else
      p.text-center(style="padding: 20px; color: #7f8c8d;") No registered deposits found.

  //- Smooth frontend toggle script tailored specifically for these cards
  script.
    function toggleExtraRows() {
      const extraRows = document.querySelectorAll('.extra-row');
      const btn = document.getElementById('toggleRowsBtn');
      const heading = document.getElementById('activityHeading');
      
      const isHidden = extraRows[0].classList.contains('d-none');
      
      extraRows.forEach(row => {
        if (isHidden) {
          row.classList.remove('d-none');
          btn.innerText = 'Show Less';
          if (heading) heading.innerText = '👥 All Customer Deposit Records';
        } else {
          row.classList.add('d-none');
          btn.innerText = 'View All Deposits';
          if (heading) heading.innerText = '🕒 Latest Activity';
          // Scroll back up smoothly to the header when collapsing long lists
          if (heading) {
            window.scrollTo({ top: heading.offsetTop - 20, behavior: 'smooth' });
          }
        }
      });
    }