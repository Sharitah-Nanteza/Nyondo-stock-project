extends layout

block content 
    .main
      .top
        h1(style="color:black;") Store Dashboard
        p Inventory control
      .cards
        .card
          h3 Total Stock
          h4(style="color:black; font-weight: bold;") #{stats.stockValue.toLocaleString()}UGX
        
        .card
          h3 Low Stock
          h2(style="color: #d9534f; font-weight: bold;") #{stats.lowStockCount}
        .card
          h3 Out of Stock
          h2(style="color: #d9534f; font-weight: bold;") #{stats.outOfStockCount}
        .card
          h3 Items
          h4(style="color:black; font-weight: bold;") #{stats.totalProducts}
      .section
        h4 Stock Alerts
        each item in dbStock
          if item.quantity === 0
            .item
              span #{item.productname}
              span(style="color: red; font-weight: bold;") Out of Stock
          else if item.quantity <= 20
            .item
              span #{item.productname}
              span(style="color: red; font-weight: bold;") Low Stock (#{item.quantity} left)
        else
          p No stock alerts at the moment!
