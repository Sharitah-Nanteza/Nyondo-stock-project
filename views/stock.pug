extends layout

block content 
  .dashboard
    h1 Stock Management
    p.stats
      | #{stats.totalProducts} products &middot; Total Stock value: #{stats.stockValue.toLocaleString()}UGX
    
    //- Action Controls Section (Both buttons side-by-side at the top)
    .d-flex.justify-content-between.align-items-center.mb-3
      a.btn-add.m-0(href='/add_stock') + Add Stock
      
      //- Move the toggle button here, only rendering if there are more than 5 products
      if dbStock.length > 5
        button#toggleRowsBtn.btn.btn-outline-primary(type="button" onclick="toggleExtraRows()") View All Products

    table
      thead
        tr
          th Product Name
          th Product Image
          th Quantity
          th Unit Cost
          th Total
          th Selling Price
          th Date
          if user.userrole === "stockmanager" || user.userrole === "admin"
            th Action
      tbody
        each product, index in dbStock
          //- If the index is 5 or greater, add the 'extra-row' class to hide it by default
          tr(class=index >= 5 ? 'extra-row d-none' : '')
            td #{product.productname}
            td 
              img(src='/'+product.image alt='Product image' width='80px' height='80px')
            td
              if product.quantity === 0
                span.badge.bg-danger Out of Stock
              else if product.quantity <= 20
                span.badge.bg-warning.text-dark Low Stock (#{product.quantity})
              else
                span.text-success #{product.quantity}
           
            td #{product.unitcost}
            td #{(product.quantity)*(product.unitcost)} 
            td #{product.sellingprice}
            td #{new Date(product.date).toLocaleString()}
            if user.userrole === "stockmanager" || user.userrole === "admin"
              td 
                .d-flex.gap-2 
                  a.btn.btn-sm.btn-outline-warning(href=`/stock/edit/${product._id}`)
                    i.fas.fa-edit
                  //- form(action=`/delete/${product._id}` method="post" onsubmit='return confirm("Are you sure you want to delete this item?");')
                  //-   button.btn.btn-sm.btn-outline-danger(type='submit')
                  //-     i.fas.fa-trash-alt 
        if dbStock.length === 0
          tr 
            td.text-center(colspan='8') No stock has been recorded yet.

  //- Tiny JavaScript snippet to handle the toggle safely without disrupting table styles
  script.
    function toggleExtraRows() {
      const extraRows = document.querySelectorAll('.extra-row');
      const btn = document.getElementById('toggleRowsBtn');
      
      // Check if the rows are currently hidden
      const isHidden = extraRows[0].classList.contains('d-none');
      
      extraRows.forEach(row => {
        if (isHidden) {
          row.classList.remove('d-none');
          btn.innerText = 'Show Less';
        } else {
          row.classList.add('d-none');
          btn.innerText = 'View All Products';
        }
      });
    }