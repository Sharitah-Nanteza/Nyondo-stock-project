extends layout 

block content 
  .main
    .header
      div
        h1 Sales Recording
        p 0 sales today &middot; Revenue: 0.00M UGX
      .text-center
        a.btn-new(href='new_sale-form.html') + New Sale
    // sales summary
    .stats-grid
      .stat-card
        small Total Sales (All Time)
        h2 4
        p(style='color:#2563eb') 4.79M UGX revenue
      .stat-card
        small Sales Today
        h2 0
        p(style='color:#2563eb') 0.00M UGX revenue
      .stat-card
        small Average Sale Value
        h2 1.20M
        p Per transaction
    // recent transaction table
    h3 Recent Transactions
    table.sales-table
      thead
        tr
          th Date / ID
          th Customer
          th Items Sold
          th Subtotal
          th Delivery
          th Total
      tbody
        tr
          td
            | 2026-04-10 
            br
            small S001
          td
            strong Kampala Hardware Ltd
            br
            small +256700111222
          td
            .item-detail Cement (Hima) x 50
