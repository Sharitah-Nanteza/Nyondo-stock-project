extends layout 

block content 
  .main
    .header
      div
        h1 Sales Recording
        p 0 sales today &middot; Revenue: 0.00M UGX
      .text-center
        a.btn-new(href='/addsale') + New Sale
    
    // sales summary
    .stats-grid
      .stat-card
        small Total Sales (All Time)
        h2 #{stats.salesToday.toLocaleString()} UGX                    
      .stat-card
        small Sales Today
        h2 0
        p(style='color:#2563eb') 0.00M UGX revenue
      .stat-card
        small Average Sale Value
        h2 1.20M
        p Per transaction
    
    //- Action Controls Section (Aligns the toggle button cleanly to the right side above the table)
    .d-flex.justify-content-between.align-items-center.mt-4.mb-2
      h3(style="margin: 0;") Recent Transactions
      if dbSales.length > 5
        button#toggleRowsBtn.btn.btn-outline-primary(type="button" onclick="toggleExtraRows()") View All Sales

    table.sales-table
      thead
        tr
          th Product Name 
          th Quantity
          th Selling Price
          th Total (UGX)
          th Customer Name
          th Customer Contact 
          th Attendant 
          th Date 
          if user.userrole === "salesattendant" || user.userrole === "admin"
            th Action 
      tbody
        //- Loop through every complete transaction record with index tracking
        each sale, index in dbSales
          //- If the invoice index is 5 or greater, hide the whole row by default
          tr(class=index >= 5 ? 'extra-row d-none' : '')
            //- 1. Product Name Column
            td
              each item in sale.items
                div(style="margin-bottom: 4px;") #{item.product ? item.product.productname : 'Item deleted'}
            
            //- 2. Quantity Column
            td
              each item in sale.items
                div(style="margin-bottom: 4px;") #{item.qty} #{item.unit || ''}
            
            //- 3. Selling Price Column
            td
              each item in sale.items
                div(style="margin-bottom: 4px;") #{item.sellingprice.toLocaleString()}
            
            //- 4. Grand Total for the entire invoice
            td(style="font-weight: bold;") #{sale.total ? sale.total.toLocaleString() : 0} 
            
            //- 5. Customer & Attendant details
            td #{sale.customername}
            td #{sale.customercontact}
            td #{sale.attendant ? sale.attendant.fullname : 'unknown'}
            td #{new Date(sale.date).toLocaleString()}
            
            //- 6. Actions (Only triggers once per complete sale document)
            if user.userrole === "salesattendant" || user.userrole === "admin"
              td
                .d-flex.gap-2  
                  a.btn.btn-sm.btn-outline-warning(href=`/sale/edit/${sale._id}`)
                    i.fas.fa-edit
                  form(action=`/sale/delete/${sale._id}` method="post" onsubmit='return confirm("Are you sure you want to delete this entire sale?");')
                    button.btn.btn-sm.btn-outline-danger(type='submit')
                      i.fas.fa-trash-alt 

        if dbSales.length === 0
          tr 
            td.text-center(colspan='9') No sales have been recorded yet.

  //- Reusable script tailored for the sales page
  script.
    function toggleExtraRows() {
      const extraRows = document.querySelectorAll('.extra-row');
      const btn = document.getElementById('toggleRowsBtn');
      
      const isHidden = extraRows[0].classList.contains('d-none');
      
      extraRows.forEach(row => {
        if (isHidden) {
          row.classList.remove('d-none');
          btn.innerText = 'Show Less';
        } else {
          row.classList.add('d-none');
          btn.innerText = 'View All Sales';
        }
      });
    }