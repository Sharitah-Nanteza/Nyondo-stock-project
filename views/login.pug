doctype html
head
  meta(charset='utf-8')
  meta(name='viewport' content='width=device-width, initial-scale=1')
  title login
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css' rel='stylesheet')
  style.
    body {
      background: linear-gradient(rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0.65)), 
                  url('https://sunrise.ug/images/2022/04/Hardware-prices-up.jpg') no-repeat center center/cover;
      height: 100vh;
      margin: 0;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    
    .card {
      width: 100%;
      max-width: 400px;
      border: none;
      background-color: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(5px);
    }

    .btn-login {
      width: 100%;
      padding: 0.75rem;
      background-color: #2563eb;
      border: none;
      color: white;
      font-weight: bold;
      border-radius: 0.5rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
      cursor: pointer;
      text-decoration: none;
    }
    .btn-login:hover {
      background-color: #1d4ed8;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }
    .btn-login:active {
      transform: scale(0.98);
    }

.card.p-4.shadow
  div
    h4(style='text-align: center; font-weight: bold; color: #1e293b;') NYONDO STOCK GENERAL HARDWARE
    p(style='text-align: center; color: #64748b;') Uganda's trusted hardware partner
    form(action="/signin" method="post") 
      .mb-3
        label.form-label(for='formGroupExampleInput2' style='font-size: 0.85rem; font-weight: 600; color: #475569;') EMAIL ADDRESS
        //- Added type='email' and required attribute
        input#formGroupExampleInput2.form-control(name='email' type='email' placeholder='Enter email address' required)
      .mb-3
        label.form-label(for='formGroupExampleInput' style='font-size: 0.85rem; font-weight: 600; color: #475569;') PASSWORD
        //- Added required attribute
        input#formGroupExampleInput.form-control(name='password' type='password' placeholder='Enter password' required)
      .mb-3.form-check
        input#autoSizingCheck.form-check-input(type='checkbox')
        label.form-check-label(for='autoSizingCheck' style='color: #475569;') Remember me
      .text-center.mt-4
        button.btn-login(type='submit') Login

script(src='https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js')
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js')