doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Nyondo Hardware - Register
  link(rel='stylesheet' href='/css/user_registration_form.css')
.container
  .header
    h1 NYONDO General Hardware LTD
    p Nansana, Wakiso District
  h2 Registration form
  form(action='/register' method='post')
    .form-group
      label(for='fullname') Full Name
      input#fullname(type='text' name='fullname' placeholder='Enter your full name' )
    .form-group
      label(for='email') Email
      input#email(type='email' name='email' placeholder='Enter your email' )
    .form-group
      label(for='phonenumber') Phone Number
      input#phonenumber(type='text' name='phonenumber' placeholder='7XXXXXXXX' pattern='[7][0-9]{8}' minlength='9' maxlength='9'  title='Enter a valid Ugandan number' )
    .form-group
      label(for='nin') NIN
      input#nin(type='text' name='nin' pattern='C[MF][0-9]{10}[A-Z]{3}' title='Enter a valid Ugandan NIN'
 placeholder='CF23MXXXXXXX')
    .form-group
      label(for='role') Role
      select(name='userrole')
        option(value='' disabled selected) Select user role
        option(value='admin') Admin
        option(value='stockmanager') Stock  Manager
        option(value='salesattendant') Sales attendant
    .form-group
      label(for='password') Password
      input#password(type='password' name='password' placeholder='At least 6 characters')
    button(type='submit') Create Account

